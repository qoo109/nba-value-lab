    "name": "bounded_injury_logit_offset_v1",
    "formula": "logit(p_candidate) = logit(p_baseline) + beta_1*z(weighted_unavailable_minutes_diff) + beta_2*z(weighted_positive_impact_diff)",
    "features": [
      "weighted_unavailable_minutes_home_minus_away",
      "weighted_absence_impact_positive_home_minus_away"
    ],
    "expected_direction": "positive feature value means more home-team burden; every fitted coefficient must be non-positive",
    "preprocessing": {
      "standardization": "training-fold mean and population standard deviation only",
      "zero_variance_feature": "STRUCTURAL_BLOCKED",
      "test_fold_statistics_used": false,
      "missing_feature_imputation": false,
      "probability_clip": [0.000001, 0.999999]
    },
    "fit": {
      "objective": "mean binary log loss plus 0.5 * l2_alpha * sum(beta^2)",
      "l2_alpha": 0.05,
      "intercept": false,
      "baseline_logit_coefficient": 1.0,
      "coefficient_bounds": [-0.5, 0.0],
      "optimizer": "L-BFGS-B",
      "initial_coefficients": [0.0, 0.0],
      "maximum_iterations": 2000,
      "tolerance": 1e-09,
      "random_seed": 20260718,
      "hyperparameter_tuning": false
    }
  },
