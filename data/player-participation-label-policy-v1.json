{
  "schema_version": "player-participation-label-policy-v1",
  "roadmap_parent": "expected_minutes_accuracy_audit",
  "frozen_population": {
    "combined_selected_independent_games": 176,
    "selection_policy": "latest_feature_ready_at_or_before_t60",
    "waves": ["wave1", "wave2"],
    "player_population": "players listed in each selected official injury snapshot"
  },
  "official_source": {
    "provider": "NBA Official LiveData Boxscore",
    "url_template": "https://cdn.nba.com/static/json/liveData/boxscore/boxscore_{official_game_id}.json",
    "required_game_status": 3,
    "target_game_fields_are_evaluation_labels_only": true,
    "retain_player_names": false,
    "retain_not_playing_descriptions": false
  },
  "label_contract": {
    "PLAYED": "official player row has played=true or positive parsed minutes",
    "EXPLICIT_DNP": "official player row has played=false and a DNP-prefixed notPlayingReason",
    "INACTIVE_OR_NOT_DRESSED": "official player row has played=false and status INACTIVE or an INACTIVE, DND, or NWT reason prefix",
    "SOURCE_MISSING": "the official game source could not be retrieved or did not pass game-level validation",
    "UNKNOWN": "the official game source passed but the player row is absent, conflicting, or not explicitly classifiable"
  },
  "structural_gates": {
    "required_combined_selected_games": 176,
    "minimum_official_game_source_coverage": 1.0,
    "minimum_identity_match_rate": 0.95,
    "minimum_participation_label_join_rate_for_matched_players": 0.95,
    "maximum_unknown_rate_for_matched_players": 0.05,
    "maximum_source_missing_games": 0,
    "duplicate_selected_games": 0,
    "duplicate_official_game_player_rows": 0,
    "duplicate_participation_audit_rows": 0,
    "team_mismatches": 0
  },
  "guardrails": {
    "missing_official_player_row_is_dnp": false,
    "missing_official_player_row_is_zero_minutes": false,
    "source_fetch_failure_is_dnp": false,
    "unknown_state_is_zero_minutes": false,
    "actual_participation_may_update_prediction": false,
    "participation_layer_directly_passes_accuracy_audit": false,
    "participation_layer_directly_enables_holdout": false,
    "participation_layer_directly_enables_model_training": false,
    "participation_layer_directly_enables_betting_claim": false
  }
}
