{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qoo109.github.io/nba-value-lab/schemas/prediction-record.schema.json",
  "title": "NBA Value Lab Minimal Prediction Record",
  "type": "object",
  "required": [
    "game_id",
    "target",
    "predicted_at",
    "stage",
    "model_v",
    "model_g",
    "p_conservative",
    "p_neutral",
    "odds",
    "grade"
  ],
  "properties": {
    "game_id": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "minLength": 2 },
    "predicted_at": { "type": "string", "format": "date-time" },
    "stage": { "enum": ["T-24h", "21:00", "T-60m", "T-5m", "Closing"] },
    "model_v": { "type": "string" },
    "model_g": { "type": "string" },
    "p_conservative": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "p_neutral": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "p_optimistic": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "odds": { "type": ["number", "null"], "exclusiveMinimum": 1 },
    "closing_odds": { "type": ["number", "null"], "exclusiveMinimum": 1 },
    "grade": { "enum": ["ㄅ", "ㄆ", "ㄇ", "不支持", "資料不足"] },
    "tier": { "enum": ["核心主推", "優先候選", "一般 ㄅ級", "條件觀察", "跳過", "資料不足"] },
    "won": { "type": ["boolean", "null"] },
    "score": { "type": ["string", "null"] },
    "data_version": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
